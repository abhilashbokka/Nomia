# Copy this file to .env and adjust as needed. Nomia loads .env automatically
# on startup (both the CLI and the local web server). All variables are
# optional; sensible defaults are used when unset.

# Where Nomia stores its config, undo journal, reports, and thumbnails.
# Defaults to the OS-standard app-data location (via `platformdirs`) when unset.
# Set this to a project-local folder for an easy-to-reset demo setup, e.g.:
# NOMIA_HOME=./nomia_data
NOMIA_HOME=

# Base URL of the Ollama server. Defaults to http://127.0.0.1:11434.
OLLAMA_HOST=http://127.0.0.1:11434

# Logging verbosity: DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
LOG_LEVEL=INFO
